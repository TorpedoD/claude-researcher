{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan.schema.json",
  "title": "Research Plan",
  "description": "Schema for the research plan produced by the orchestrator during the planning phase",
  "type": "object",
  "required": ["subtopics", "priorities", "expected_source_types", "estimated_coverage_areas"],
  "properties": {
    "subtopics": {
      "type": "array",
      "description": "Research subtopics with priority ranking and guiding questions",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Subtopic name (human-readable)",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "description": "Priority ranking (1 = highest priority)",
            "minimum": 1
          },
          "questions": {
            "type": "array",
            "description": "Specific questions to investigate for this subtopic",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "priorities": {
      "type": "array",
      "description": "Ordered list of subtopic names by priority (highest first)",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "expected_source_types": {
      "type": "array",
      "description": "Source types to seek during collection",
      "items": {
        "type": "string",
        "enum": ["docs", "paper", "blog", "code", "forum", "other"]
      },
      "minItems": 1
    },
    "estimated_coverage_areas": {
      "type": "array",
      "description": "Broad topic domains the research should span",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "section_depths": {
      "type": "array",
      "description": "Per-section depth assignments written at Gate 1 (Phase 12 D-09). One entry per section/subsection in the planned output. Depth is LOCKED after Gate 1 approval — synthesizer may expand upward but never downgrade.",
      "items": {
        "type": "object",
        "required": ["section", "depth"],
        "properties": {
          "section": {
            "type": "string",
            "description": "Section name (typically H2 or H3 heading text)",
            "minLength": 1
          },
          "depth": {
            "type": "string",
            "description": "Depth level per Phase 12 D-10/D-11/D-12",
            "enum": ["low", "medium", "high"]
          },
          "justification": {
            "type": "string",
            "description": "Why this depth was auto-assigned (e.g. 'L0 question tree node', 'semantic importance: core mechanism')",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "depth_overrides": {
      "type": "array",
      "description": "User overrides applied at Gate 1 (Phase 12 D-08). Records original auto-assigned depth and user's override for audit.",
      "items": {
        "type": "object",
        "required": ["section", "original_depth", "override_depth"],
        "properties": {
          "section": {
            "type": "string",
            "minLength": 1
          },
          "original_depth": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "override_depth": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "override_reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
