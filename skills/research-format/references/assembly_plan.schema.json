{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assembly_plan.schema.json",
  "title": "Assembly Plan",
  "description": "Lightweight report composition plan built from sliced claim state.",
  "type": "object",
  "required": ["canonical_report_path", "sections", "format_preferences"],
  "properties": {
    "canonical_report_path": {"type": "string", "const": "output/report.md"},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["section_id", "title", "order", "section_brief_path", "claim_slice_path", "output_path", "source_ids"],
        "properties": {
          "section_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
          "title": {"type": "string", "minLength": 1},
          "order": {"type": "integer", "minimum": 1},
          "section_brief_path": {"type": "string", "pattern": "^synthesis/section_briefs/.+\\.json$"},
          "claim_slice_path": {"type": "string", "pattern": "^synthesis/claim_slices/.+\\.json$"},
          "output_path": {"type": "string", "pattern": "^output/sections/.+\\.md$"},
          "source_ids": {
            "type": "array",
            "items": {"type": "string", "pattern": "^src_[0-9]{3,}$"},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "format_preferences": {
      "type": "object",
      "required": ["mode", "audience", "tone"],
      "properties": {
        "mode": {"type": "string", "minLength": 1},
        "audience": {"type": "string", "minLength": 1},
        "tone": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
