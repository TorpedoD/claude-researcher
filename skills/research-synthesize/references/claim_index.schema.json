{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim_index.schema.json",
  "title": "Claim Index",
  "description": "Legacy compatibility schema derived from claim_bank.json on explicit request.",
  "type": "object",
  "required": ["claims", "metadata"],
  "properties": {
    "claims": {
      "type": "array",
      "description": "Array of derived claim references with supporting source IDs",
      "items": {
        "type": "object",
        "required": ["claim_text", "claim_hash", "section", "sources"],
        "properties": {
          "claim_text": {
            "type": "string",
            "description": "The factual claim text copied from claim_bank.json",
            "minLength": 1
          },
          "claim_hash": {
            "type": "string",
            "description": "SHA-256 hash of normalized claim text",
            "minLength": 1
          },
          "section": {
            "type": "string",
            "description": "Section heading where the claim appears",
            "minLength": 1
          },
          "sources": {
            "type": "array",
            "description": "Supporting sources for this claim",
            "items": {
              "type": "object",
              "required": ["source_id"],
              "properties": {
                "source_id": {
                  "type": "string",
                  "pattern": "^src_[0-9]{3,}$"
                }
              },
              "additionalProperties": false
            }
          },
          "origin": {
            "type": "string",
            "description": "Provenance label for gap-fill pipeline (SYNTH-12): original=from pass-1 evidence, gap-fill=introduced by gap-fill re-synthesis",
            "enum": ["original", "gap-fill"]
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Aggregate statistics about the compatibility index",
      "required": ["total_claims", "compatibility_only"],
      "properties": {
        "total_claims": {
          "type": "integer",
          "description": "Total number of claims indexed",
          "minimum": 0
        },
        "compatibility_only": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
